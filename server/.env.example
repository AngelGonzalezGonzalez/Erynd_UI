# ERYND server config — copy to server/.env and fill in.

# SQLite for local dev. Switch to a postgresql:// URL + schema provider later.
DATABASE_URL="file:./dev.db"

# The single seeded workspace.
WORKSPACE_ID="ws-erynd"

# Bearer token the frontend must present on /api calls. Leave blank for open
# local dev; set it (and VITE_WORKSPACE_TOKEN to match) to require auth.
WORKSPACE_TOKEN="erynd-dev-token"

# The agent. Without a key the server falls back to the offline rules agent.
ANTHROPIC_API_KEY=""

PORT=8787
# Comma-separated allowed origins; defaults to all in dev.
CORS_ORIGIN="http://localhost:5173"
