{
  "name": "erynd-intelligence",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ERYND — AI-first media intelligence platform (interactive prototype)",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
